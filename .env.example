# Copy this file to .env and fill in your API keys.
# The app works with any subset of keys; unconfigured sources are skipped
# and flagged in the UI. See README.md for a walkthrough of each registration.

# NewsAPI.org — register at https://newsapi.org/register
# Note: the free Developer plan only allows browser requests from localhost.
VITE_NEWSAPI_API_KEY=

# The Guardian Open Platform — register at https://open-platform.theguardian.com/access/
VITE_GUARDIAN_API_KEY=

# New York Times — register at https://developer.nytimes.com/get-started
# and enable the "Article Search API" for your app.
VITE_NYT_API_KEY=
